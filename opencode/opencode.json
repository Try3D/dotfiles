{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "keybinds": {
    "messages_page_up": "ctrl+u",
    "messages_page_down": "ctrl+d",
  }
}
