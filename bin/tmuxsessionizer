#!/bin/zsh

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(echo -e "[New project]\n$(find ~/Projects ~/Experiments/ -mindepth 1 -maxdepth 1 -type d)" | fzf)

    if [[ $selected == "[New project]" ]]; then
        category=$(echo -e "Experiments\nProjects" | fzf)

        if [[ -z $category ]]; then
            exit 0
        fi

        read "project_name?Enter project name: "

        if [[ -z $project_name ]]; then
            exit 0
        fi

        selected="$HOME/$category/$project_name"
        mkdir -p "$selected"
    fi
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [ ! $tmux_running ]; then
    tmux new-session -s $selected_name -c $selected
    exit 0
fi

if [ -z "$TMUX" ]; then
    tmux new-session -A -s $selected_name -c $selected
    exit 0
fi

if ! tmux has-session -t $selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

tmux switch-client -t $selected_name
